  "keyFeatures": [
    "Hardware Abstraction Layer (HAL) for roboRIO control",
    "Command-based programming framework for Java and C++",
    "Advanced control theory with state-space controllers",
    "Robot simulation with GUI tools and custom extensions",
    "NetworkTables for real-time robot communication",
    "Computer vision with cscore and AprilTag detection",
    "Comprehensive math library with kinematics and trajectory generation",
    "Type-safe units system for physical measurements",
    "SysId tool for system identification and characterization",
    "Multiple drivetrain support (differential, mecanum, swerve)"
  ],
  "publicApiSurface": [
    "edu.wpi.first.wpilibj (WPILibJ - Java robot framework)",
    "frc namespace (WPILibC - C++ robot framework)",
    "edu.wpi.first.hal (Hardware Abstraction Layer)",
