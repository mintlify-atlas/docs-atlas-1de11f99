    "edu.wpi.first.networktables (NetworkTables communication)",
    "edu.wpi.first.cscore (Camera server and video streaming)",
    "edu.wpi.first.apriltag (AprilTag detection)",
    "edu.wpi.first.units (Type-safe units)",
    "edu.wpi.first.util (Utility classes)",
    "HALSIM extensions API (Simulation plugins)",
    "Motor controller classes (PWM, CAN)",
    "Sensor classes (Encoders, Gyros, Accelerometers)",
    "Drivetrain kinematics (Differential, Mecanum, Swerve)",
    "PID controllers and state-space controllers",
    "Trajectory generation and following",
    "Pose estimation and odometry"
  ]
